# =============================================================================
# Plantilla de variables (sin secretos — sí va a Git).
#
# En el proyecto usa:
#   .env.dev     → npm run dev + preview Vercel (rama develop)
#   .env.prod    → producción negsai.com
#
# Subir a Vercel: .\scripts\sync-vercel-env.ps1 -Target prod|dev -Sync
# (o automático con /vercel prod | /vercel dev)
# =============================================================================

# --- Sitio (público) ---
# Local: http://localhost:3000 | Producción: https://www.negsai.com (canónico en Vercel)
NEXT_PUBLIC_SITE_URL=https://www.negsai.com

# Search Console → Configuración → Verificación → Etiqueta HTML (solo el código, sin comillas)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Perfiles públicos separados por coma (JSON-LD sameAs)
# NEXT_PUBLIC_SAME_AS=https://www.linkedin.com/company/negsai

# --- Cloudflare Turnstile (anti-spam del formulario) ---
# Dashboard: https://dash.cloudflare.com → Turnstile → widget negsai.com
# En dev puedes dejar vacío (el formulario funciona en modo desarrollo sin backend estricto).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Supabase (formulario → tabla contact_leads) ---
# URL: Project Settings → API
# SERVICE_ROLE: misma página — "service_role" (secreto, solo servidor / Vercel)
# Migración: supabase/migrations/20260603000000_contact_leads.sql
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (email a rchaves@negsai.com) ---
# https://resend.com/api-keys — verifica dominio negsai.com para enviar desde contacto@negsai.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Negsai <rchaves@negsai.com>
CONTACT_NOTIFY_EMAIL=rchaves@negsai.com

# =============================================================================
# VERCEL — añadir las MISMAS variables en:
#   Project negsai-web → Settings → Environment Variables
#
# | Variable                         | Production | Preview (develop) |
# |----------------------------------|------------|---------------------|
# | NEXT_PUBLIC_SITE_URL             | ✓          | https://www.negsai.com (prod) |
# | NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION | ✓      | opcional, token Search Console |
# | NEXT_PUBLIC_SAME_AS              | ✓          | opcional, URLs separadas por coma |
# | NEXT_PUBLIC_TURNSTILE_SITE_KEY   | ✓          | ✓ (mismo o clave de test) |
# | TURNSTILE_SECRET_KEY             | ✓          | ✓ |
# | SUPABASE_URL                     | ✓          | ✓ |
# | SUPABASE_SERVICE_ROLE_KEY        | ✓          | ✓ |
# | RESEND_API_KEY                   | ✓          | ✓ |
# | RESEND_FROM_EMAIL                | ✓          | ✓ |
# | CONTACT_NOTIFY_EMAIL             | ✓          | ✓ |
#
# Tras guardar: Redeploy en Production y Preview.
# =============================================================================
